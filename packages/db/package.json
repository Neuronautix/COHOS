{
  "name": "@cohos/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "pnpm prisma:generate && tsc -p tsconfig.json",
    "prisma:generate": "prisma generate --config prisma.config.ts",
    "prisma:validate": "prisma validate --config prisma.config.ts",
    "seed": "tsx src/seed.ts",
    "typecheck": "pnpm prisma:generate && tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@cohos/domain": "workspace:*",
    "@prisma/client": "^7.8.0"
  },
  "devDependencies": {
    "prisma": "^7.8.0"
  }
}
